OPENAI_API_KEY=
PMM_CHUNK_SECONDS=900
PMM_CHUNK_OVERLAP_SECONDS=5
PMM_AUDIO_BITRATE=32k
PMM_OPENAI_MODEL=whisper-1

PMM_TRANSCRIPTION_BACKEND=funasr-sensevoice
PMM_LOCAL_WHISPER_MODEL=small
PMM_LOCAL_WHISPER_DEVICE=cpu
PMM_LOCAL_WHISPER_LANGUAGE=zh
PMM_LOCAL_WHISPER_TASK=transcribe
PMM_OUTPUT_SIMPLIFIED_CHINESE=true

PMM_FUNASR_MODEL=iic/SenseVoiceSmall
PMM_FUNASR_VAD_MODEL=fsmn-vad
PMM_FUNASR_PUNC_MODEL=ct-punc
PMM_FUNASR_DEVICE=cpu
PMM_FUNASR_LANGUAGE=zh
PMM_FUNASR_BATCH_SIZE_S=60
PMM_FUNASR_MERGE_LENGTH_S=15

PMM_ENABLE_EMBEDDINGS=true
PMM_EMBEDDING_BACKEND=local
PMM_LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
PMM_LOCAL_EMBEDDING_DEVICE=cpu
PMM_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PMM_SEMANTIC_CANDIDATES=400
PMM_SEMANTIC_MIN_SCORE=0.36
PMM_EMBEDDING_QUERY_INSTRUCTION=
PMM_SEARCH_CANDIDATE_MULTIPLIER=4

PMM_ENABLE_LOCAL_RERANKER=true
PMM_LOCAL_RERANKER_MODEL=BAAI/bge-reranker-base
PMM_LOCAL_RERANKER_DEVICE=cpu
PMM_RERANKER_CANDIDATES=80

PMM_ENABLE_ASSISTANT=true
PMM_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PMM_LLM_API_KEY=
PMM_LLM_MODEL=deepseek-v4-flash
PMM_ASSISTANT_CANDIDATES=50
PMM_ASSISTANT_QUERY_TERMS=12

PMM_DATA_DIR=.pmm_data
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_RETRIES=5
PIP_TIMEOUT=120

HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_SYMLINKS_WARNING=1
PMM_MODEL_DOWNLOAD_BACKEND=modelscope
MODELSCOPE_CACHE=.pmm_data/ms
HF_HOME=.pmm_data/hf
HF_HUB_CACHE=.pmm_data/hf/hub
TRANSFORMERS_CACHE=.pmm_data/tf
SENTENCE_TRANSFORMERS_HOME=.pmm_data/st
TORCH_HOME=.pmm_data/torch

PMM_FFMPEG_BIN=
PMM_FFPROBE_BIN=
